# .env.example
# 复制为 .env 然后填入真实值，或直接用环境变量

FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id
FEISHU_WEBHOOK_SECRET=
TARGET_REGIONS=us-east-1,us-west-2,ap-northeast-1

# EventBridge Scheduler 调度
# cron 语法：cron(Minutes Hours Day-of-month Month Day-of-week Year)
# 默认每天 09:00（按 SCHEDULE_TIMEZONE 所在时区）
SCHEDULE_EXPRESSION=cron(0 9 * * ? *)
# IANA 时区；Scheduler 原生支持，不需要再手动换算 UTC
SCHEDULE_TIMEZONE=Asia/Shanghai

# Stack 部署到哪个 Region（CDK 原生变量，没有 -c 形式）
CDK_DEFAULT_REGION=us-east-1
